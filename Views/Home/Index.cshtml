﻿

    <div class="container py-5">
        <div class="row mb-5">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-dark mb-2">Hoş Geldiniz, <span class="text-primary">Tarsan Et </span></h1>
                <p class="lead text-black">İşletme takip ve kalite kontrol yönetim paneli.</p>
            </div>
            <div class="col-lg-4 text-lg-end d-flex align-items-center justify-content-lg-end">
                <div class="bg-primary bg-opacity-10 p-3 rounded-4 d-inline-flex align-items-center">
                    <i class="bi bi-calendar3 fs-4 text-primary me-3"></i>
                    <div class="text-start">
                        <div class="small text-muted fw-semibold">Bugün</div>
                        <div class="fw-bold text-dark">@DateTime.Now.ToString("dd MMMM yyyy")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Muayene ve Analiz -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-primary p-2 rounded-3 me-3">
                    <i class="bi bi-search text-white fs-5"></i>
                </div>
                <h3 class="fw-bold mb-0">Muayene ve Analiz</h3>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="bi bi-file-earmark-medical text-primary fs-4"></i>
                                </div>
                                <h5 class="fw-bold mb-0">Ante Mortem</h5>
                            </div>
                            <p class="text-muted small mb-4">Kesim öncesi hayvan muayene kayıtları ve sağlık raporları.</p>
                            <a asp-controller="AnteMortemReport" asp-action="Index" class="btn btn-light rounded-pill w-100 fw-bold stretched-link">Yönet</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="bi bi-file-earmark-medical text-danger fs-4"></i>
                                </div>
                                <h5 class="fw-bold mb-0">Post Mortem</h5>
                            </div>
                            <p class="text-muted small mb-4">Kesim sonrası karkas muayene ve organ kontrol kayıtları.</p>
                            <a asp-controller="PostMortemReport" asp-action="Index" class="btn btn-light rounded-pill w-100 fw-bold stretched-link">Yönet</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="bi bi-check2-all text-info fs-4"></i>
                                </div>
                                <h5 class="fw-bold mb-0">Geçerli Kılma & Doğrulama</h5>
                            </div>
                            <p class="text-muted small mb-4">GGYS geçerli kılma ve doğrulama kayıtları (TE-FR.056).</p>
                            <a asp-controller="ValidationVerification" asp-action="Index" class="btn btn-light rounded-pill w-100 fw-bold stretched-link">Yönet</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                                    <i class="bi bi-graph-up text-success fs-4"></i>
                                </div>
                                <h5 class="fw-bold mb-0">Analiz Raporları</h5>
                            </div>
                            <p class="text-muted small mb-4">Laboratuvar mikrobiyolojik ve kimyasal analiz sonuçları.</p>
                            <a asp-controller="AnalysisReport" asp-action="Index" class="btn btn-light rounded-pill w-100 fw-bold stretched-link">Yönet</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hijyen ve Kalite -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-info p-2 rounded-3 me-3">
                    <i class="bi bi-shield-check text-white fs-5"></i>
                </div>
                <h3 class="fw-bold mb-0">Hijyen ve Kalite Yönetimi</h3>
            </div>
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-droplet text-info fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">Temizlik Kontrol</h6>
                            <p class="text-muted x-small mb-4">Günlük temizlik ve dezenfeksiyon doğrulama formları.</p>
                            <a asp-controller="CleaningControl" asp-action="Index" class="btn btn-outline-info btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition bg-dark text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <i class="bi bi-clipboard-check fs-2 text-success"></i>
                                <span class="badge bg-success rounded-pill">Aktif</span>
                            </div>
                            <h5 class="fw-bold">Ürün Hazırlama</h5>
                            <p class="text-white-50 small mb-4">Üretim reçeteleri ve hazırlık kayıtları</p>
                            <a asp-controller="ProductPrepration" asp-action="Index" class="btn btn-success rounded-pill w-100 fw-bold stretched-link">Ürün Reçeteye Git</a>
                        </div>
                    </div>
                </div>
         
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-calendar-check text-primary fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">Temizlik Planı</h6>
                            <p class="text-muted x-small mb-4">Ekipman ve alan bazlı periyodik temizlik talimatları.</p>
                            <a asp-controller="CleaningPlan" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-exclamation-octagon text-warning fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">Uygunsuzluk Formu</h6>
                            <p class="text-muted x-small mb-4">Uygun olmayan malzeme ve hizmet takip formu (TE-FR.11).</p>
                            <a asp-controller="NonConformingProduct" asp-action="Index" class="btn btn-outline-warning btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-shield-check text-success fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">HACCP Planı</h6>
                            <p class="text-muted x-small mb-4">Kritik Kontrol Noktaları ve HACCP planları (TE-PL.001).</p>
                            <a asp-controller="HaccpPlan" asp-action="Index" class="btn btn-outline-success btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-thermometer-half text-secondary fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">Ölçüm Cihazları</h6>
                            <p class="text-muted x-small mb-4">Termometre ve terazi kalibrasyon takip kayıtları.</p>
                            <a asp-controller="MeasurementDevice" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-exclamation-triangle text-danger fs-3 mb-3 d-block"></i>
                            <h6 class="fw-bold">Düzeltici Faaliyet</h6>
                            <p class="text-muted x-small mb-4">Uygunsuzluk yönetimi ve düzeltici önleyici faaliyetler.</p>
                            <a asp-controller="CorrectiveAction" asp-action="Index" class="btn btn-outline-danger btn-sm rounded-pill w-100 stretched-link">Aç</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Üretim ve Verimlilik -->
        <div class="mb-5">
            <div class="d-flex align-items-center mb-4">
                <div class="bg-warning p-2 rounded-3 me-3">
                    <i class="bi bi-gear text-dark fs-5"></i>
                </div>
                <h3 class="fw-bold mb-0">Üretim ve Verimlilik</h3>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition bg-dark text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <i class="bi bi-clipboard-check fs-2 text-success"></i>
                                <span class="badge bg-success rounded-pill">Aktif</span>
                            </div>
                            <h5 class="fw-bold">Sevkiyat Kontrol</h5>
                            <p class="text-white-50 small mb-4">Günlük sevkiyat miktarları ve takip.</p>
                            <a asp-controller="Shipment" asp-action="Index" class="btn btn-success rounded-pill w-100 fw-bold stretched-link">Sevkiyata Git</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition bg-dark text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <i class="bi bi-clipboard-check fs-2 text-success"></i>
                                <span class="badge bg-success rounded-pill">Aktif</span>
                            </div>
                            <h5 class="fw-bold">Stok Kontrol</h5>
                            <p class="text-white-50 small mb-4">Günlük Stok takip.</p>
                            <a asp-controller="Stock" asp-action="Index" class="btn btn-success rounded-pill w-100 fw-bold stretched-link">Stok Kartlarına Git</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <i class="bi bi-box-seam text-warning fs-3 mb-3 d-block"></i>
                            <h5 class="fw-bold">İzlenebilirlik</h5>
                            <p class="text-muted small mb-4">Girdi ve çıktı partilerinin geriye dönük takibi.</p>
                            <a asp-controller="Kesim" asp-action="Index" class="btn btn-light rounded-pill w-100 fw-bold stretched-link">İncele</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded text-center">
                                        <i class="bi bi-calculator text-primary"></i>
                                        <div class="x-small fw-bold text-primary mt-1">Karkas</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-success bg-opacity-10 p-2 rounded text-center">
                                        <i class="bi bi-percent text-success"></i>
                                        <div class="x-small fw-bold text-success mt-1">Randıman</div>
                                    </div>
                                </div>
                            </div>
                            <h5 class="fw-bold">Verim Hesaplama</h5>
                            <p class="text-muted small mb-4">Karkas parçalama ve kesim randıman analizleri.</p>
                            <div class="d-flex gap-2">
                                <a asp-controller="CarcassYield" asp-action="Index" class="btn btn-outline-primary btn-sm rounded-pill flex-grow-1">Karkas</a>
                                <a asp-controller="SlaughterYield" asp-action="Index" class="btn btn-outline-success btn-sm rounded-pill flex-grow-1">Randıman</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lojistik ve Dokümantasyon -->
        <div>
            <div class="d-flex align-items-center mb-4">
                <div class="bg-secondary p-2 rounded-3 me-3">
                    <i class="bi bi-folder text-white fs-5"></i>
                </div>
                <h3 class="fw-bold mb-0">Lojistik ve Dokümantasyon</h3>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3">
                                <i class="bi bi-truck text-primary fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Mal Kabul</h6>
                                <p class="text-muted x-small mb-0">Girdi kontrol ve depo kabul kayıtları.</p>
                            </div>
                            <a asp-controller="GoodsReceipt" asp-action="Index" class="ms-auto btn btn-link text-primary stretched-link">
                                <i class="bi bi-arrow-right-circle fs-4"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition bg-dark text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <i class="bi bi-clipboard-check fs-2 text-success"></i>
                                <span class="badge bg-success rounded-pill">Aktif</span>
                            </div>
                            <h5 class="fw-bold">Sevkiyat Yöetim Paneli</h5>
                            <p class="text-white-50 small mb-4">Sevkiyat Kontrol.</p>
                            <a asp-controller="Shipment" asp-action="Index" class="btn btn-success rounded-pill w-100 fw-bold stretched-link">Sevkiyat Yönetimine Git</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition bg-dark text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <i class="bi bi-clipboard-check fs-2 text-success"></i>
                                <span class="badge bg-success rounded-pill">Aktif</span>
                            </div>
                            <h5 class="fw-bold">Doküman Yönetimi</h5>
                            <p class="text-white-50 small mb-4">Prosedür, talimat ve form arşivi.</p>
                            <a asp-controller="Document" asp-action="Index" class="btn btn-success rounded-pill w-100 fw-bold stretched-link">Doküman Yönetimine Git</a>
                        </div>
                    </div>
                </div>
          
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 p-3 rounded-4 me-3">
                                <i class="bi bi-people text-warning fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Toplantı Tutanağı</h6>
                                <p class="text-muted x-small mb-0">GGYS ve yönetim toplantı tutanakları (TE-FR.035).</p>
                            </div>
                            <a asp-controller="MeetingMinute" asp-action="Index" class="ms-auto btn btn-link text-warning stretched-link">
                                <i class="bi bi-arrow-right-circle fs-4"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift transition">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 p-3 rounded-4 me-3">
                                <i class="bi bi-chat-quote text-success fs-3"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Müşteri İkna</h6>
                                <p class="text-muted x-small mb-0">Sıkça sorulan sorular ve cevaplar.</p>
                            </div>
                            <a asp-controller="CustomerFaq" asp-action="Index" class="ms-auto btn btn-link text-success stretched-link">
                                <i class="bi bi-arrow-right-circle fs-4"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.1) !important;
        }

        .transition {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .x-small {
            font-size: 0.75rem;
        }

        .card {
            overflow: hidden;
        }

        body {
            background-color: #f8f9fa;
        }
    </style>

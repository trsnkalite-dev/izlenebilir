        let currentCalcId = 0;

        async function loadRecipeAndCalculate() {
            const productName = document.getElementById('productSelect').value;
            const targetAmount = parseFloat(document.getElementById('targetAmount').value) || 0;
            const tbody = document.querySelector('#ingredientsTable tbody');
            const thisCalcId = ++currentCalcId;

            if (!productName) {
                tbody.innerHTML = '';
                updateTotal();
                return;
            }

            // 1. Try to find recipe from API first, then hardcoded
            let recipeItems = [];
            const apiRecipe = apiRecipes.find(r => (r.name || r.Name) === productName);
            
            if (apiRecipe) {
                const items = apiRecipe.items || apiRecipe.Items || [];
                recipeItems = items.map(item => ({
                    name: item.ingredientName || item.IngredientName,
                    ratio: (item.percentage || item.Percentage || 0) / 100
                }));
                const code = apiRecipe.code || apiRecipe.Code;
                if (code) document.querySelector('input[name="DocumentNo"]').value = code;
            } else if (hardcodedRecipes[productName]) {
                recipeItems = hardcodedRecipes[productName];
                if (docNos[productName]) document.querySelector('input[name=\"DocumentNo\"]').value = docNos[productName];
            } else {
                tbody.innerHTML = '<tr><td colspan=\"6\" class=\"text-center text-muted\">Reçete bulunamadı.</td></tr>';
                return;
            }

            // 2. Fetch stock info for ingredients from STOCKS API (Anlık Stok)
            const ingredientNames = recipeItems.map(item => item.name);
            console.log("Fetching stock info for:", ingredientNames);
            let stockInfo = {};
            try {
        const response = await fetch('https://localhost:7241/api/Stocks/latest-bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(ingredientNames)
                });
                if (response.ok) {
                    stockInfo = await response.json();
                    console.log("Stock info received:", stockInfo);
                }
            } catch (error) {
                console.error("Stock info fetch error:", error);
            }

            if (thisCalcId !== currentCalcId) return;
            tbody.innerHTML = ''; 

            recipeItems.forEach(item => {
                const amount = (item.ratio * targetAmount).toFixed(2);
                
                // Try to find the stock info by exact name, then case-insensitive
                const stock = stockInfo[item.name] || 
                             stockInfo[Object.keys(stockInfo).find(k => k.toLowerCase() === item.name.toLowerCase())] || 
                             {};
                
                console.log(`Matching item ${item.name} -> found stock:`, stock);

                addRow({ 
                    id: stock.id || stock.Id || 0,
                    name: item.name, 
                    amount: amount, 
                    batchNo: stock.lotNo || stock.LotNo || '', 
                    expiryDate: stock.expiryDate || stock.ExpiryDate || '',
                    depo: stock.depoAdi || stock.DepoAdi || '-',
                    stockQty: stock.currentQuantity || stock.CurrentQuantity || 0
                });
            });
            updateTotal();
        }

        async function fetchLotsForIngredient(input, preSelectedId = null) {
            const name = input.value.trim();
            const row = input.closest('tr');
            const lotSelect = row.querySelector('.lotSelector');
            const batchInput = row.querySelector('.batchNo');
            
            if (!name) return;

            try {
        const response = await fetch(`https://localhost:7241/api/Stocks?search=${encodeURIComponent(name)}`);
                if (response.ok) {
                    const allStocks = await response.json();
                    
                    // Improved matching: try exact match first, then includes
                    let filtered = allStocks.filter(s => (s.stockName || s.StockName || '').toLowerCase() === name.toLowerCase() && (s.quantity || s.Quantity) >= 0);
                    if (filtered.length === 0) {
                        filtered = allStocks.filter(s => (s.stockName || s.StockName || '').toLowerCase().includes(name.toLowerCase()) && (s.quantity || s.Quantity) >= 0);
                    }
                    
                    if (filtered.length > 0) {
                        lotSelect.innerHTML = '<option value="">Seçiniz...</option>';
                        filtered.forEach(s => {
                            const sId = s.id || s.Id;
                            const option = document.createElement('option');
                            option.value = sId;
                            option.text = `${s.lotNo || s.LotNo} (${(s.quantity || s.Quantity || 0).toFixed(1)} kg) - ${s.depoAdi || s.DepoAdi}`;
                            option.dataset.json = JSON.stringify(s);
                            if (preSelectedId && String(sId) === String(preSelectedId)) {
                                option.selected = true;
                            }
                            lotSelect.appendChild(option);
                        });
                        lotSelect.style.display = 'block';
                        batchInput.style.display = 'none';
                        
                        // If we have a preSelectedId, make sure fields are updated
                        if (preSelectedId) {
                            onLotChange(lotSelect);
                        }
                    } else {
                        lotSelect.style.display = 'none';
                        batchInput.style.display = 'block';
                    }
                }
            } catch (error) {
                console.error("Lot fetching error:", error);
            }
        }

        function onLotChange(select) {
            const row = select.closest('tr');
            const option = select.options[select.selectedIndex];
            if (!option || !option.dataset.json) return;

            const stock = JSON.parse(option.dataset.json);
            
            row.querySelector('.stockId').value = stock.id || stock.Id;
            row.querySelector('.batchNo').value = stock.lotNo || stock.LotNo;
            const expiryDateInput = row.querySelector('.expiryDate');
            if (expiryDateInput) {
                const rawDate = stock.expiryDate || stock.ExpiryDate;
                const date = new Date(rawDate);
                expiryDateInput.value = isNaN(date.getTime()) ? (rawDate || '') : date.toLocaleDateString('tr-TR');
            }
            row.querySelector('.depo').value = stock.depoAdi || stock.DepoAdi;
            const stockQtyDisplay = row.querySelectorAll('input[readonly]')[1];
            if (stockQtyDisplay) {
                stockQtyDisplay.value = parseFloat(stock.quantity || stock.Quantity || 0).toFixed(1);
            }
        }

        function addRow(data = {}) {
            const tbody = document.querySelector('#ingredientsTable tbody');
            const tr = document.createElement('tr');
            tr.className = 'ingredient-row';
            const stockQty = parseFloat(data.stockQty) || 0;
            const stockId = data.id || 0;

            tr.innerHTML = `
                <td>
                    <input type="hidden" class="stockId" value="${stockId}" />
                    <input type="text" class="form-control form-control-sm name" value="${data.name || ''}" onblur="fetchLotsForIngredient(this)" />
                </td>
                <td>
                    <div class="input-group input-group-sm">
                        <select class="form-select form-select-sm lotSelector" onchange="onLotChange(this)" style="display:none; max-width: 200px;">
                            <option value="">Seçiniz...</option>
                        </select>
                        <input type="text" class="form-control form-control-sm depo text-xs" value="${data.depo || '-'}" readonly style="max-width: 180px;" />
                        <input type="text" class="form-control form-control-sm batchNo" value="${data.batchNo || ''}" placeholder="Parti No" />
                    </div>
                </td>
                <td><input type="text" class="form-control form-control-sm expiryDate" value="${data.expiryDate || ''}" /></td>
                <td><input type="text" class="form-control form-control-sm text-center bg-light text-primary fw-bold" value="${stockQty.toFixed(1)}" readonly /></td>
                <td><input type="number" step="0.01" class="form-control form-control-sm text-center amount ${data.amount > stockQty ? 'is-invalid' : ''}" value="${data.amount || '0.00'}" oninput="updateTotal()" /></td>
                <td class="text-center"><button type="button" class="btn btn-sm text-danger" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>
            `;
            tbody.appendChild(tr);
            if (data.name) {
                fetchLotsForIngredient(tr.querySelector('.name'), stockId);
            }
            updateTotal();
        }

        function removeRow(btn) {
            btn.closest('tr').remove();
            updateTotal();
        }

        function updateTotal() {
            const amounts = document.querySelectorAll('.amount');
            let total = 0;
            amounts.forEach(input => {
                total += parseFloat(input.value) || 0;
            });
            document.getElementById('totalDisplay').innerText = total.toFixed(2);
            document.getElementById('TotalAmountHidden').value = total.toFixed(2);
        }
    </script>
}












            // Unify submission logic
            $('#prepForm').on('submit', function() {
                // 1. Gather ingredients data
                const rows = document.querySelectorAll('.ingredient-row');
                const data = Array.from(rows).map(row => ({
                    StockId: parseInt(row.querySelector('.stockId').value) || 0,
                    Name: row.querySelector('.name').value,
                    BatchNo: row.querySelector('.batchNo').value,
                    ExpiryDate: row.querySelector('.expiryDate').value,
                    Amount: parseFloat(row.querySelector('.amount').value) || 0
                }));
                document.getElementById('IngredientsDataHidden').value = JSON.stringify(data);

                // 2. Visual feedback and prevent double click
                const btn = $('#btnSubmit');
                btn.prop('disabled', true);
                $('#submitText').text('Kaydediliyor...');
                return true;
            });

            // Initialize select2
            $('#productSelect').select2({
                placeholder: "Ürün Seçiniz...",
                allowClear: true,
                width: '100%'
            }).on('change.select2', function() {
                loadRecipeAndCalculate();
            });

            // Load recipes from API to supplement hardcoded ones
            loadRecipesFromApi();
        });


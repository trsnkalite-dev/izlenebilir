                        const rName = r.name || r.Name;
                        if (rName && select.find(`option[value="${rName}"]`).length === 0) {
                            select.append(new Option(rName, rName));
                        }
                    });
                }
            } catch (error) {
                console.error("Error loading recipes:", error);

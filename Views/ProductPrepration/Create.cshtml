﻿

@model KaliteWeb.UI.Dto.ProductPreparationDto.ProductPreparationDto.CreateProductPreparationDto

@{
    ViewData["Title"] = "Yeni Ürün Hazırlama Formu";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-lg rounded-4 p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0 text-primary">Yeni Ürün Hazırlama Formu</h3>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i>Listeye Dön
            </a>
        </div>

        <form asp-action="Create" method="post" id="prepForm">
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Doküman No</label>
                    <input asp-for="DocumentNo" class="form-control rounded-3" value="TE-FR-77" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Yayın Tarihi</label>
                    <input asp-for="PublishDate" type="date" class="form-control rounded-3" value="2025-03-07" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Rev. No</label>
                    <input asp-for="RevisionNo" class="form-control rounded-3" value="1" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Rev. Tarih</label>
                    <input asp-for="RevisionDate" class="form-control rounded-3" value="02.11.2025" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Sayfa No</label>
                    <input asp-for="PageNo" class="form-control rounded-3" value="1/1" />
                </div>
            </div>

            <div class="row g-3 mb-4 bg-light p-3 rounded-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Tarih</label>
                    <input asp-for="Date" type="date" class="form-control rounded-3" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ürün Seçimi</label>
                  <select asp-for="ProductName" class="form-select rounded-3" id="productSelect">
                        <option value="">Ürün Seçiniz...</option>
                        <option value="ADANA KÖFTE">ADANA KÖFTE</option>
                        <option value="DANA KIYMA DÖNER">DANA KIYMA DÖNER</option>
                        <option value="DANA SOSİS">DANA SOSİS</option>
                        <option value="SUCUK">SUCUK</option>
                        <option value="DANA DÖNER">DANA DÖNER</option>
                        <option value="İNEGÖL KÖFTE">İNEGÖL KÖFTE</option>
                        <option value="DANA MACAR SALAM">DANA MACAR SALAM</option>
                        <option value="DANA ANTRİKOT">DANA ANTRİKOT</option>
                        <option value="PİLİÇ DÖNER">PİLİÇ DÖNER</option>
                        <option value="PİLİÇ SOSİS">PİLİÇ SOSİS</option>
                        <option value="ŞEFTALİ KEBABI">ŞEFTALİ KEBABI</option>
                        <option value="BURGER KÖFTE">BURGER KÖFTE</option>
                        <option value="KASAP KÖFTE">KASAP KÖFTE</option>
                        <option value="DANA ANTRİKOT">DANA ANTRİKOT</option>
                        <option value="DANA KONTRAFİLE">DANA KONTRAFİLE</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Hedef Miktar (kg)</label>
                    <input type="number" step="0.01" class="form-control rounded-3 fw-bold text-primary" id="targetAmount" value="100" oninput="loadRecipeAndCalculate()" />
                </div>
              
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Parti No</label>
                    <input asp-for="BatchNo" class="form-control rounded-3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Hamur Sıcaklık</label>
                    <input asp-for="DoughTemp" class="form-control rounded-3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Hamur PH</label>
                    <input asp-for="DoughPh" class="form-control rounded-3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Ortam Sıcaklık</label>
                    <input asp-for="AmbientTemp" class="form-control rounded-3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Dolum Sıcaklık</label>
                    <input asp-for="FillingTemp" class="form-control rounded-3" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Kontrol</label>
                    <input asp-for="Control" class="form-control rounded-3" value="KYS" />
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>Hedef Depo (Üretilen Ürünün Gireceği Yer)</label>
                    <select asp-for="DepoId" class="form-control" required>
                        <option value="">Depo Seçiniz...</option>
                        @foreach (var depo in ViewBag.Depos) // Controller'dan depoları gönderin
                        {
                            <option value="@depo.DepoId">@depo.DepoAdi</option>
                        }
                    </select>
                </div>
            </div>

            <h5 class="fw-bold mb-3 text-secondary"><i class="bi bi-list-check me-2"></i>Kullanılan Katkı Maddeleri</h5>
            <div class="table-responsive mb-4">
                <table class="table table-bordered align-middle" id="ingredientsTable">
                    <thead class="bg-light text-center small fw-bold">
                        <tr>
                            <th style="width: 250px;">Ürün Adı</th>
                            <th>Depo / Parti No (Tercih Edilen)</th>
                            <th style="width: 120px;">S.K.T.</th>
                            <th style="width: 100px;">Toplam Stok</th>
                            <th style="width: 120px;">Kullanılan (kg)</th>
                            <th style="width: 40px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Dynamic rows -->
                    </tbody>
                    <tfoot>
                        <tr class="bg-light fw-bold">
                            <td colspan="4" class="text-end">TOPLAM KARIŞIM:</td>
                            <td class="text-center text-primary" id="totalDisplay">0.00</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
                <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3" onclick="addRow()">
                    <i class="bi bi-plus-circle me-1"></i>Manuel Satır Ekle
                </button>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Hazırlayan</label>
                    <input asp-for="PreparedBy" class="form-control rounded-3" placeholder="İsim Soyisim" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Onaylayan</label>
                    <input asp-for="ApprovedBy" class="form-control rounded-3" placeholder="İsim Soyisim" />
                </div>
            </div>

            <input type="hidden" asp-for="IngredientsData" id="IngredientsDataHidden" />
            <input type="hidden" asp-for="TotalAmount" id="TotalAmountHidden" />

            <div class="text-end">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm" id="btnSubmit">
                    <i class="bi bi-check2-circle me-2"></i><span id="submitText">Kaydet</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/css/select2.min.css" rel="stylesheet" />

@model CreateStockDto

@{
    ViewData["Title"] = "Yeni Stok Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string[] commonAllergens = { "Glüten", "Yumurta", "Balık", "Yer Fıstığı", "Soya", "Süt / Laktoz", "Sert Kabuklu Meyveler", "Kereviz", "Hardal", "Susam", "Sülfit", "Acı Bakla", "Yumuşakçalar" };
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gray-50 py-8 px-4">
    <div class="max-w-3xl mx-auto">
        <div class="bg-white border-0 shadow-2xl rounded-3xl overflow-hidden">
            <div class="bg-blue-600 text-white p-6 md:p-8">
                <div class="flex justify-between items-center">
                    <div>
                        <h4 class="text-2xl font-bold flex items-center gap-2">
                            <i class="bi bi-plus-circle"></i> Yeni Stok Kaydı
                        </h4>
                        <p class="text-blue-100 mt-1">Sisteme yeni ürün stok girişi yapın.</p>
                    </div>
                    <a href="/Stock/Index" class="bg-white/20 hover:bg-white/30 p-2 rounded-full transition-all">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>

            <div class="p-6 md:p-8">
                <form asp-action="CreateStock" method="post" class="space-y-6">
                    <input type="hidden" id="FinalAllergenInfo" name="AllergenInfo" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <i class="bi bi-exclamation-triangle-fill text-red-500"></i>
                                </div>
                                <div class="ml-3">
                                    <div asp-validation-summary="All" class="text-sm text-red-700"></div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label asp-for="StockName" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Ürün Adı</label>
                            <input asp-for="StockName" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Örn: Dana Karkas" required />
                        </div>

                        <div>
                            <label asp-for="StockKodu" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Stok Kodu</label>
                            <input asp-for="StockKodu" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Örn: 12456664" required />
                        </div>

                        <div>
                            <label asp-for="Barcod" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Barkod</label>
                            <input asp-for="Barcod" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Barkod no..." />
                        </div>

                        <div>
                            <label asp-for="LotNo" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Lot No</label>
                            <input asp-for="LotNo" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Örn: 2024-001" required />
                        </div>

                        <div>
                            <label asp-for="ExpiryDate" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Son Kullanma Tarihi</label>
                            <input type="date" asp-for="ExpiryDate" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" required />
                        </div>

                        <div>
                            <label asp-for="CompanyName" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Firma</label>
                            <input asp-for="CompanyName" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Tedarikçi firma adı..." />
                        </div>

                        <div>
                            <label asp-for="DepoAdi" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Depo / Lokasyon</label>
                            <select asp-for="DepoAdi" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none">
                                <option value="">Depo Seçiniz...</option>
                                @if (ViewBag.Warehouses != null)
                                {
                                    foreach (var item in ViewBag.Warehouses)
                                    {
                                        <option value="@item">@item</option>
                                    }
                                }
                            </select>
                        </div>

                        <div>
                            <label asp-for="Quantity" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Miktar</label>
                            <input type="number" step="0.1" asp-for="Quantity" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" placeholder="Örn: 500" required />
                        </div>

                        <div class="md:col-span-2">
                            <label asp-for="Grup" class="block text-sm font-bold text-gray-700 mb-2 uppercase tracking-wide">Grup</label>
                            <select asp-for="Grup" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all outline-none" required>
                                <option value="">Grup Seçiniz...</option>
                                <option value="Canlı">Canlı</option>
                                <option value="Hammadde">Hammadde</option>
                                <option value="Yardımcı Madde">YardimciMadde</option>
                                <option value="Katkı Maddesi">KatkiMaddesi</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-8">
                        <label class="block text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide flex items-center gap-2">
                            <i class="bi bi-shield-exclamation text-yellow-500"></i> Alerjen Bilgisi
                        </label>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 p-5 bg-gray-50 rounded-2xl border border-gray-100">
                            @foreach (var allergen in commonAllergens)
                            {
                                <label class="flex items-center gap-2 p-2 hover:bg-white hover:shadow-sm rounded-lg cursor-pointer transition-all">
                                    <input type="checkbox" class="allergen-checkbox w-5 h-5 text-blue-600 rounded border-gray-300 focus:ring-blue-500" value="@allergen" />
                                    <span class="text-sm text-gray-600">@allergen</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="pt-8 flex gap-4 mt-6">
                        <a href="/Anlik/Index" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-4 rounded-2xl text-center transition-all">
                            İptal
                        </a>
                        <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-200 transition-all transform active:scale-95">
                            Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const checkboxes = document.querySelectorAll('.allergen-checkbox');
        const hiddenInput = document.getElementById('FinalAllergenInfo');

        function updateAllergenInfo() {
            const selected = Array.from(checkboxes)
                .filter(cb => cb.checked)
                .map(cb => cb.value);

            hiddenInput.value = selected.join(', ');
        }

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateAllergenInfo);
        });
    });
</script>



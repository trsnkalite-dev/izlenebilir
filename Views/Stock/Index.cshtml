@model List<ResultStockDto>


@{
    ViewData["Title"] = "Stok Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0">Stok Yönetimi</h2>
            <p class="text-muted small">Güncel ürün stok durumlarını buradan takip edebilirsiniz.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="GoodsReceipt" asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-truck me-2"></i>Mal Kabul
            </a>
            <a asp-controller="ProductPrepration" asp-action="Create" class="btn btn-info text-white rounded-pill px-4 shadow-sm">
                <i class="bi bi-gear-wide-connected me-2"></i>Üretim
            </a>
            <a href="/Stock/CreateStock" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Yeni Stok Ekle
            </a>
        </div>
    </div>

    <!-- Arama ve Filtreleme -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form method="get" action="/Stock/Index" class="row g-3">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="search" value="@ViewBag.SearchSearch" class="form-control border-start-0 rounded-end-pill py-2" placeholder="Ürün adı, Lot No, Firma veya Depo ara...">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2">Filtrele</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-shadow transition">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill me-1">@item.DepoAdi</span>
                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill">@item.Grup</span>
                                </div>
                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm">
                                        <li><a class="dropdown-item" href="/Stock/UpdateStock/@item.Id"><i class="bi bi-pencil me-2"></i>Düzenle</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="/Stock/DeleteStock/@item.Id" onclick="return confirm('Bu stok kaydını silmek istediğinize emin misiniz?')"><i class="bi bi-trash me-2"></i>Sil</a></li>
                                    </ul>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-2">@item.StockName</h5>
                            <div class="mb-3">
                                <div class="d-flex align-items-center text-muted small mb-1">
                                    <i class="bi bi-tag me-2"></i>Stok Kodu: <span class="ms-1 fw-medium text-dark">@item.StockKodu</span>
                                </div>
                                <div class="d-flex align-items-center text-muted small mb-1">
                                    <i class="bi bi-hash me-2"></i>Lot No: <span class="ms-1 fw-medium text-dark">@item.LotNo</span>
                                </div>
                                <div class="d-flex align-items-center text-muted small mb-1">
                                    <i class="bi bi-box me-2"></i>Miktar: <strong class="ms-1 text-primary">@item.Quantity.ToString("N1")</strong>
                                </div>
                                <div class="d-flex align-items-center text-muted small mb-1">
                                    <i class="bi bi-building me-2"></i>Firma: <span class="ms-1 fw-medium text-dark">@item.CompanyName</span>
                                </div>
                                <div class="d-flex align-items-center text-muted small">
                                    <i class="bi bi-calendar-event me-2"></i>SKT: <span class="ms-1 fw-medium @(item.ExpiryDate < DateTime.Now.AddDays(7) ? "text-danger" : "text-dark")">@(item.ExpiryDate?.ToString("dd.MM.yyyy") ?? "Belirtilmedi")</span>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(item.AllergenInfo))
                            {
                                <div class="p-2 bg-warning-subtle text-warning-emphasis rounded-3 small">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@item.AllergenInfo
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sayfalama -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center gap-2">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link rounded-circle" href="/Stock/Index?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.SearchSearch">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link rounded-circle" href="/Stock/Index?page=@i&search=@ViewBag.SearchSearch">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link rounded-circle" href="/Stock/Index?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.SearchSearch">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam display-1 text-muted opacity-25"></i>
            <h4 class="mt-3 text-muted">Stok bulunamadı</h4>
            <p class="text-muted">Arama kriterlerinizi değiştirerek tekrar deneyebilirsiniz.</p>
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .page-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        color: #333;
    }

    .page-item.active .page-link {
        background-color: var(--bs-primary);
        color: white;
    }
</style>


